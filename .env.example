# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is git-ignored. Coolify injects these
# per-service in production (Phase 8). Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (shared by web + scraper) ------------------------------------
# Matches the docker-compose Postgres service for local dev.
DATABASE_URL=postgres://insider:insider@localhost:5432/insiderclusters

# --- Scraper (Phase 1) -----------------------------------------------------
# SEC requires a real contact in the User-Agent or it returns 403.
SEC_USER_AGENT=InsiderClusters support@beelodev.com
# Signal filter: only P (open-market buy) transactions at/above this USD value.
# Nominal $1 floor = capture every real open-market purchase (max data).
MIN_SIGNAL_VALUE=1
# Market-cap ceiling (USD). Unset = disabled (clusters form at any company size,
# incl. mega-caps). Set a finite value to re-enable a size gate.
# MAX_MARKET_CAP=2000000000
# Rolling window (days) for grouping distinct insiders into a cluster.
CLUSTER_WINDOW_DAYS=90
# Poll interval in seconds.
POLL_INTERVAL_SECONDS=300

# --- Auth (Phase 2) --------------------------------------------------------
APP_URL=http://localhost:3000
# AUTH_TOKEN_TTL_MINUTES=15

# --- Email alerts (Phase 5) ------------------------------------------------
# Resend API key. When unset, the scraper logs what it would send (no real
# email, no clusters marked dispatched) and web logs magic links to console.
# RESEND_API_KEY=
# From address (must be on a Resend-verified domain). Display name is fine.
ALERT_FROM_EMAIL=InsiderClusters <support@beelodev.com>
# Free-tier weekly digest cadence (days between digests per user).
# DIGEST_INTERVAL_DAYS=7

# --- Billing: Lemon Squeezy (Phase 4) — fill when we get there --------------
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Discord bot (Phase 6) — fill when we get there ------------------------
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=
# DISCORD_ALERTS_CHANNEL_ID=
# DISCORD_PAID_ROLE_ID=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# --- Auth session (Phase 2) ---
AUTH_SESSION_TTL_DAYS=30
AUTH_TOKEN_TTL_MINUTES=15
# In non-production, request-link returns the magic link in the JSON response
# for local testing. Never enabled in production.

# --- Analytics: PostHog ----------------------------------------------------
# Same phc_… project key is used everywhere. The server-side vars feed
# posthog-node (custom backend events, error tracking). The NEXT_PUBLIC_ copies
# are exposed to the browser and consumed by web/instrumentation-client.ts —
# WITHOUT them the browser SDK never initializes, so pageviews, autocapture, and
# session replay are not captured (server events still work).
POSTHOG_API_KEY=phc_your_project_key
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
