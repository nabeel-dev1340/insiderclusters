# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (match anywhere in the monorepo, not just root)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# builds
build/
dist/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env / secrets (never commit; use .env.example instead)
.env
.env.local
.env*.local

# local postgres data
.data/
pgdata/

# misc
.DS_Store
*.pem

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
