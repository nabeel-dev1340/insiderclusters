{
  "name": "insiderclusters",
  "version": "0.1.0",
  "private": true,
  "description": "Insider Cluster-Buy Alert Platform — monorepo (web + scraper + shared db)",
  "workspaces": [
    "web",
    "scraper",
    "packages/*"
  ],
  "scripts": {
    "migrate": "node --env-file-if-exists=.env packages/db/migrate.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "dev:web": "npm run dev --workspace web",
    "dev:scraper": "npm run dev --workspace scraper"
  },
  "engines": {
    "node": ">=22"
  }
}
